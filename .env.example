# ──── 数据库 ─────────────────────────────────────────────
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB 由 start.sh 阶段 8 自动创建并校验。
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_change_me
POSTGRES_DB=leadgen
DATABASE_URL=postgresql+asyncpg://postgres:postgres_secret_change_me@127.0.0.1:5432/leadgen

# ──── Redis ──────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ──── API Keys ───────────────────────────────────────────
SERPER_API_KEY=d87ea6614d227331fbfe5b0c41df44c028b8f661
BING_API_KEY=

# ──── 应用安全 ────────────────────────────────────────────
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:80,http://127.0.0.1:80,http://localhost:3000,http://127.0.0.1:3000

# ──── Flower 监控认证 ─────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# ──── 代理配置 ────────────────────────────────────────────
PROXY_LIST=
PROXY_API_URL=
PROXY_API_KEY=

# ──── 并发控制 ────────────────────────────────────────────
MAX_CONCURRENT_SEARCHES=5
MAX_CONCURRENT_SCRAPERS=3
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=5

# ──── 功能开关 ────────────────────────────────────────────
ENABLE_PROXY=false
ENABLE_ROBOTS_CHECK=true
PLAYWRIGHT_HEADLESS=true
