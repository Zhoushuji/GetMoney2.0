[Unit]
Description=LeadGen Celery Beat
After=network.target redis.service leadgen-worker.service
Wants=redis.service leadgen-worker.service

[Service]
Type=simple
User=__DEPLOY_USER__
WorkingDirectory=__SCRIPT_DIR__/backend
EnvironmentFile=__ENV_FILE__
ExecStart=__VENV_DIR__/bin/celery -A app.workers.celery_app.celery_app beat --loglevel=info
Restart=always
RestartSec=5
StandardOutput=append:__LOG_DIR__/beat.log
StandardError=append:__LOG_DIR__/beat.log

[Install]
WantedBy=multi-user.target
